{
  "name": "@viett.2/contracts",
  "version": "1.0.5",
  "description": "protobuf contracts for Cinema",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "protoc -I ./proto ./proto/*.proto --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./gen --ts_proto_opt=nestJs=true,package=omit"
  },
  "files": [
    "dist",
    "proto",
    "gen"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "ts-proto": "^2.11.6",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@nestjs/microservices": "^11.1.17",
    "rxjs": "^7.8.2"
  }
}
